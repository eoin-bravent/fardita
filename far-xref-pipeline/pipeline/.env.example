# Pipeline defaults & secret. Copy to `.env` and fill in.
# Precedence: CLI flags > .env / real env > pipeline.config.json > built-in defaults.

# --- secret (required for the live LLM pass) ---
# Your USAi.gov API key. (USAI_API_KEY is also accepted; GEMINI_API_KEY kept for back-compat.)
GEMINI_API_KEY=
# USAi.gov agency-specific endpoint, e.g. https://<agency>.usai.gov — REQUIRED for the live LLM pass.
USAI_BASE_URL=

# --- model defaults (USAi.gov is OpenAI-compatible) ---
GEMINI_MODEL=gemini-2.5-pro
GEMINI_REASONING=true
# GEMINI_THINKING_BUDGET=-1        # -1 = dynamic
GEMINI_JUDGE=false                 # optional 2nd LLM pass that pre-fills review recommendations

# --- LLM backend selector ---
# usai (default, stdlib REST) or vertex (Google Vertex AI via google-genai).
# LLM_PROVIDER=usai

# --- Vertex AI backend (only when LLM_PROVIDER=vertex) ---
# Auth is Application Default Credentials — same as the Java sample GSA gave you.
# Point this at the service-account JSON key file (do NOT commit the key):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Project / location (defaults to the GSA sample values if unset):
# GOOGLE_CLOUD_PROJECT=prj-t-ogp-acqsplcy-mvcai
# GOOGLE_CLOUD_LOCATION=us-central1
# Requires: pip install -r requirements-vertex.txt

# --- optional pipeline defaults (else from pipeline.config.json) ---
# PIPELINE_REGULATION=FAR
# PIPELINE_INPUT_DIR=../..
# PIPELINE_BOTTOM_LEVEL=paragraph
# PIPELINE_OUTPUT_DIR=out
